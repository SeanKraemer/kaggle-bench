{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "data/schema/candidate_actions.schema.json",
  "title": "CandidateActionBank",
  "description": "Schema for data/tasks/<competition_slug>/candidate_actions.json",
  "type": "object",
  "required": [
    "competition_slug",
    "generated_at",
    "actions"
  ],
  "properties": {
    "competition_slug": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/candidate_action"
      }
    }
  },
  "$defs": {
    "string_array": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "candidate_action": {
      "type": "object",
      "required": [
        "action_id",
        "action_type",
        "canonical_params",
        "eval_stage",
        "role",
        "difficulty",
        "reasoning",
        "provenance_type"
      ],
      "properties": {
        "action_id": {
          "type": "string",
          "minLength": 1
        },
        "action_type": {
          "type": "string",
          "minLength": 1
        },
        "canonical_params": {
          "type": "object"
        },
        "eval_stage": {
          "type": "string",
          "enum": [
            "core_preprocessing",
            "validation_protocol",
            "model_specific_preprocessing"
          ]
        },
        "role": {
          "type": "string",
          "enum": [
            "good",
            "bad"
          ]
        },
        "difficulty": {
          "type": "string",
          "enum": [
            "easy",
            "medium",
            "hard"
          ]
        },
        "reasoning": {
          "type": "string",
          "minLength": 1
        },
        "provenance_type": {
          "type": "string",
          "enum": [
            "observed_notebook",
            "synthetic"
          ]
        },
        "notebook_refs": {
          "$ref": "#/$defs/string_array"
        },
        "base_refs": {
          "$ref": "#/$defs/string_array"
        },
        "derived_from_action_ids": {
          "$ref": "#/$defs/string_array"
        },
        "derivation_reasoning": {
          "type": "string",
          "minLength": 1
        },
        "source_profile": {
          "type": "string",
          "minLength": 1
        },
        "context_notes": {
          "type": "string",
          "minLength": 1
        },
        "evidence_snippets": {
          "$ref": "#/$defs/string_array"
        },
        "rareness": {
          "type": "string",
          "enum": [
            "common",
            "uncommon",
            "rare"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "equivalence_group": {
          "type": "string",
          "minLength": 1
        },
        "must_follow_action_ids": {
          "$ref": "#/$defs/string_array"
        },
        "invalidates_action_ids": {
          "$ref": "#/$defs/string_array"
        },
        "conflicts_with_action_ids": {
          "$ref": "#/$defs/string_array"
        },
        "challenge_type": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "provenance_type": {
                "const": "observed_notebook"
              }
            },
            "required": [
              "provenance_type"
            ]
          },
          "then": {
            "required": [
              "notebook_refs"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "provenance_type": {
                "const": "synthetic"
              }
            },
            "required": [
              "provenance_type"
            ]
          },
          "then": {
            "required": [
              "derivation_reasoning"
            ],
            "anyOf": [
              {
                "required": [
                  "base_refs"
                ]
              },
              {
                "required": [
                  "derived_from_action_ids"
                ]
              }
            ]
          }
        },
        {
          "if": {
            "properties": {
              "role": {
                "const": "good"
              }
            },
            "required": [
              "role"
            ]
          },
          "then": {
            "properties": {
              "provenance_type": {
                "const": "observed_notebook"
              }
            },
            "required": [
              "provenance_type",
              "notebook_refs",
              "source_profile",
              "context_notes",
              "evidence_snippets",
              "rareness",
              "confidence"
            ]
          }
        }
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
