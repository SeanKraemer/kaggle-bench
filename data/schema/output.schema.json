{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "data/schema/output.schema.json",
  "title": "EvalOutputArtifact",
  "description": "Schema for one output run artifact under data/tasks/<competition_slug>/outputs/*.json and human_baseline/*.json.",
  "type": "object",
  "required": [
    "competition_slug",
    "testcase_id",
    "agent_name",
    "run_by",
    "run_id",
    "artifact_refs",
    "predicted_add_action_ids",
    "predicted_remove_action_ids",
    "time_spent_seconds",
    "token_usage",
    "notes"
  ],
  "properties": {
    "competition_slug": {
      "type": "string",
      "minLength": 1
    },
    "testcase_id": {
      "type": "string",
      "minLength": 1
    },
    "agent_name": {
      "type": "string",
      "minLength": 1
    },
    "run_by": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifact_ref"
      }
    },
    "predicted_add_action_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "predicted_remove_action_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "time_spent_seconds": {
      "type": "number",
      "minimum": 0
    },
    "token_usage": {
      "type": "object",
      "required": [
        "input_tokens",
        "output_tokens",
        "total_tokens"
      ],
      "properties": {
        "input_tokens": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "output_tokens": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "total_tokens": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "artifact_ref": {
      "type": "object",
      "required": [
        "kind",
        "path"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "trace",
            "log",
            "metadata",
            "notebook",
            "notes",
            "prompt",
            "stream",
            "scratchpad",
            "tool_calls",
            "api_calls",
            "other"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
